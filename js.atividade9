let usuario;
let senha;
let tentativas = 0;

while (tentativas < 3) {
    usuario = prompt("Usuário:");
    senha = prompt("Senha:");

    if (usuario === "admin" && senha === "1234") {
        alert("Login realizado com sucesso!");
        break;
    } else {
        alert("Dados incorretos!");
        tentativas++;
    }
}

if (tentativas === 3) {
    alert("Acesso bloqueado!");
}
